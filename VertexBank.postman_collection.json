{
  "info": {
    "name": "VertexBank",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8080" },
    { "key": "user_url", "value": "http://localhost:8082" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teste@vertexbank.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "console.log('Token salvo:', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teste@vertexbank.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "console.log('Token renovado:', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{auth_url}}/auth/validate?token={{token}}",
              "query": [{ "key": "token", "value": "{{token}}" }]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', '');",
                  "pm.collectionVariables.set('refreshToken', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User Service",
      "item": [
        {
          "name": "Criar Perfil",
          "request": {
            "method": "POST",
            "url": "{{user_url}}/users",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marcos\",\n  \"cpf\": \"12345678909\",\n  \"email\": \"teste@vertexbank.com\",\n  \"dataNascimento\": \"1999-05-20\",\n  \"address\": {\n    \"rua\": \"Rua das Flores\",\n    \"numero\": \"123\",\n    \"bairro\": \"Centro\",\n    \"cidade\": \"São Paulo\",\n    \"estado\": \"SP\",\n    \"cep\": \"01310-100\"\n  },\n  \"phones\": [\n    { \"numero\": \"11999999999\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Buscar Meu Perfil",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Atualizar Meu Perfil",
          "request": {
            "method": "PUT",
            "url": "{{user_url}}/users/me",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marcos Atualizado\",\n  \"email\": \"novo@vertexbank.com\",\n  \"address\": {\n    \"rua\": \"Avenida Paulista\",\n    \"numero\": \"1000\",\n    \"bairro\": \"Bela Vista\",\n    \"cidade\": \"São Paulo\",\n    \"estado\": \"SP\",\n    \"cep\": \"01311-100\"\n  }\n}"
            }
          }
        },
        {
          "name": "Acesso Sem Token (deve retornar 401)",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/me"
          }
        }
      ]
    }
  ]
}
